<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NascentiaFlow"
             xmlns:views="clr-namespace:NascentiaFlow.Views"
             xmlns:vm="clr-namespace:NascentiaFlow.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="NascentiaFlow.Views.MainView"
             x:DataType="vm:MainViewModel">
    <UserControl.DataTemplates>
        <DataTemplate x:DataType="vm:AppLoadingViewModel">
            <TextBlock>
                Application is starting...
            </TextBlock>
        </DataTemplate>

        <DataTemplate x:DataType="vm:AppContentViewModel">
            <Grid>
                <Grid.RowDefinitions>Auto,*</Grid.RowDefinitions>
                <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>

                <!-- Navigation bar -->
                <views:NavigationBar Grid.Row="0" Grid.Column="0" Name="Navigation" />

                <!-- Main content area -->
                <ContentControl Grid.Row="1" Grid.Column="0" Name="Screen" Content="{Binding CurrentScene}">
                    <ContentControl.DataTemplates>
                        <local:SceneLocator />
                    </ContentControl.DataTemplates>
                </ContentControl>

                <!-- Tool panel -->
                <ContentControl
                    Name="ToolPanel"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    Content="{Binding CurrentScene}"
                    Width="88"
                    Background="LightBlue">
                    <ContentControl.DataTemplates>
                        <local:SceneToolPanelLocator />
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Grid>
        </DataTemplate>

        <DataTemplate x:DataType="vm:AppDismissingViewModel">
            <TextBlock>The app is closing...</TextBlock>
        </DataTemplate>
    </UserControl.DataTemplates>

    <ContentControl Content="{Binding CurrentAppViewModel}" />
</UserControl>
